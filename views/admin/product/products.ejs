<%
    const pageData = {
        title: 'Customer Management - Carezon Admin',
        pageTitle: 'Customer Management',
        breadcrumb: [
            { name: 'Home', url: '/admin' },
            { name: 'Customer Management', url: '/admin/userManagement' }
        ]
