    <!-- Custom JS -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Edit profile field functionality
            const editButtons = document.querySelectorAll('.profile-field .btn-link');
            
            editButtons.forEach(button => {
                button.addEventListener('click', function() {
                    const inputField = this.previousElementSibling;
                    inputField.readOnly = !inputField.readOnly;
                    inputField.disabled = !inputField.disabled;
                    
                    if (!inputField.readOnly || !inputField.disabled) {
                        inputField.focus();
                        this.innerHTML = '<i class="fas fa-check"></i>';
                    } else {
                        this.innerHTML = '<i class="fas fa-pencil-alt"></i>';
                    }
                });
            });
            
            // Edit button functionality
            const editButton = document.querySelector('.btn-edit');
            
            editButton.addEventListener('click', function() {
                const inputFields = document.querySelectorAll('.profile-field input, .profile-field select, .profile-field textarea');
                
                inputFields.forEach(field => {
                    field.readOnly = false;
                    field.disabled = false;
                });
                
                this.innerHTML = 'Save';
                this.classList.remove('btn-edit');
                this.classList.add('btn-primary');
                
                this.addEventListener('click', function() {
                    inputFields.forEach(field => {
                        field.readOnly = true;
                        field.disabled = true;
                    });
                    
                    this.innerHTML = 'Edit';
                    this.classList.remove('btn-primary');
                    this.classList.add('btn-edit');
                    
                    // Here you would typically send the updated data to the server
                    alert('Profile updated successfully!');
                }, { once: true });
            });
        });
    </script>
